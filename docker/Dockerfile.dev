# Dockerfile.dev - Optimized for fast local development
FROM ruby:3.3.3-alpine3.19

# --- Arguments and Environment ---
ARG NODE_VERSION_ARG="23.7.0"
ARG PNPM_VERSION_ARG="10.2.0"
ARG BUNDLER_VERSION_ARG="2.5.11"

ENV NODE_VERSION=${NODE_VERSION_ARG}
ENV PNPM_VERSION=${PNPM_VERSION_ARG}
ENV BUNDLER_VERSION=${BUNDLER_VERSION_ARG}

# Development environment settings
ENV RAILS_ENV="development"
ENV NODE_ENV="development"
ENV BUNDLE_WITHOUT=""
ENV NODE_OPTIONS="--max-old-space-size=4096 --openssl-legacy-provider"
ENV BUNDLE_PATH="/usr/local/bundle"
ENV BUNDLE_BIN="$BUNDLE_PATH/bin"
ENV GEM_HOME=$BUNDLE_PATH
ENV GEM_PATH=$BUNDLE_PATH

ENV PNPM_HOME="/root/.local/share/pnpm"
ENV PATH="${PNPM_HOME}:${BUNDLE_BIN}:/usr/local/bin:${PATH}"

# --- Install System Dependencies ---
RUN apk update && apk add --no-cache \
    build-base \
    tzdata \
    postgresql-dev \
    postgresql-client \
    git \
    curl \
    xz \
    musl-dev \
    openssl \
    openssl-dev \
    vips \
    imagemagick \
    bash \
    && rm -rf /var/cache/apk/*

# --- Install Bundler ---
RUN gem install bundler -v "${BUNDLER_VERSION}" --no-document \
    && bundle config --global silence_root_warning 1

# --- Install Node.js & PNPM ---
# Install Node.js
RUN curl -fsSL https://nodejs.org/dist/v${NODE_VERSION}/node-v${NODE_VERSION}-linux-x64-musl.tar.xz -o node.tar.xz \
    && tar -xJf node.tar.xz -C /usr/local --strip-components=1 \
    && rm node.tar.xz \
    && npm install -g pnpm@${PNPM_VERSION} \
    && pnpm --version

WORKDIR /app

# --- Install Gems (this layer will be cached unless Gemfile changes) ---
COPY Gemfile Gemfile.lock ./
RUN bundle config set --local force_ruby_platform true \
    && bundle install --jobs "$(nproc)" --retry 3

# --- Install PNPM Packages (this layer will be cached unless package.json changes) ---
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

# --- Create essential directories ---
RUN mkdir -p /app/log \
    && mkdir -p /app/tmp/pids \
    && mkdir -p /app/tmp/cache \
    && mkdir -p /app/public/packs

# --- Set up entrypoint ---
COPY docker/entrypoints/dev.sh /usr/bin/dev.sh
RUN chmod +x /usr/bin/dev.sh

EXPOSE 3000

ENTRYPOINT ["/usr/bin/dev.sh"] 